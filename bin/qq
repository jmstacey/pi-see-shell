#!/usr/bin/env zsh
# qq — continue the previous q answer in the same shell session.

if ! command -v pi &>/dev/null; then
  echo "✗ 'pi' not found." >&2; exit 1
fi
[[ $# -eq 0 ]] && { echo "Usage: qq <follow-up question>" >&2; exit 1; }

source "${0:A:h}/.pi-see-shell-question.zsh"

local transcript_file
transcript_file="$(pi_see_shell_transcript_path)"
if [[ ! -f "$transcript_file" ]]; then
  print -P "%F{red}✗ No active question. Start one with: q <question>%f" >&2
  exit 1
fi

local pi_model_args=()
[[ -n "${PI_SEE_SHELL_PROVIDER:-}" ]] && pi_model_args+=(--provider "$PI_SEE_SHELL_PROVIDER")
[[ -n "${PI_SEE_SHELL_MODEL:-}" ]] && pi_model_args+=(--model "$PI_SEE_SHELL_MODEL")

local mode system_prompt prompt answer ret
mode="$(pi_see_shell_read_mode)"
system_prompt="$(pi_see_shell_system_prompt "$mode")"
prompt="$(pi_see_shell_followup_prompt "$*")"

printf '%s' "$*" | pi_see_shell_append_turn user

print -P ""
print -P "%F{cyan}│ Follow-up:%f %F{yellow}$*%f"
print -P ""

answer="$(pi --print -p \
  "${pi_model_args[@]}" \
  --system-prompt "$system_prompt" \
  --tools "read,web_search,url_extract,web_fetch,batch_web_fetch" \
  --no-skills \
  --no-context-files \
  --no-prompt-templates \
  --no-themes \
  --no-session \
  --thinking "${PI_SEE_SHELL_THINKING:-off}" \
  "$prompt")"
ret=$?

if [[ $ret -ne 0 ]]; then
  print -P "%F{red}✗ Failed.%f"
  exit $ret
fi

printf '%s' "$answer" | pi_see_shell_append_turn assistant
print -r -- "$answer"
