#!/usr/bin/env zsh
# q — ask a question and get an AI-powered answer.

if ! command -v pi &>/dev/null; then
  echo "✗ 'pi' not found." >&2; exit 1
fi
[[ $# -eq 0 ]] && { echo "Usage: q <question>" >&2; exit 1; }

source "${0:A:h}/.pi-see-shell-question.zsh"

pi_see_shell_write_mode concise
pi_see_shell_reset_transcript
printf '%s' "$*" | pi_see_shell_append_turn user

local system_prompt
system_prompt="$(pi_see_shell_system_prompt concise)"

print -P ""
print -P "%F{cyan}┌─────────────────────────────────────────────%f"
print -P "%F{cyan}│ Question:%f %F{yellow}$*%f"
print -P "%F{cyan}└─────────────────────────────────────────────%f"
print -P ""

local pi_model_args=()
[[ -n "${PI_SEE_SHELL_PROVIDER:-}" ]] && pi_model_args+=(--provider "$PI_SEE_SHELL_PROVIDER")
[[ -n "${PI_SEE_SHELL_MODEL:-}" ]] && pi_model_args+=(--model "$PI_SEE_SHELL_MODEL")
if [[ -n "${PI_SEE_SHELL_MODEL:-}" ]]; then
  local pi_models_pattern="$PI_SEE_SHELL_MODEL"
  if [[ -n "${PI_SEE_SHELL_PROVIDER:-}" && "$pi_models_pattern" != "$PI_SEE_SHELL_PROVIDER/"* ]]; then
    pi_models_pattern="$PI_SEE_SHELL_PROVIDER/$pi_models_pattern"
  fi
  pi_model_args+=(--models "$pi_models_pattern")
fi

local prompt answer ret
prompt="$*"
answer="$(pi --print -p \
  "${pi_model_args[@]}" \
  --system-prompt "$system_prompt" \
  --tools "read,web_search,url_extract,web_fetch,batch_web_fetch" \
  --no-skills \
  --no-context-files \
  --no-prompt-templates \
  --no-themes \
  --no-session \
  --thinking "${PI_SEE_SHELL_Q_THINKING:-${PI_SEE_SHELL_THINKING:-off}}" \
  "$prompt")"
ret=$?

if [[ $ret -ne 0 ]]; then
  print -P "%F{red}✗ Failed.%f"
  exit $ret
fi

printf '%s' "$answer" | pi_see_shell_append_turn assistant
print -r -- "$answer"
