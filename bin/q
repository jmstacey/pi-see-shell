#!/usr/bin/env zsh
# q — ask a question and get an AI-powered answer
#
# Usage:  q <question>
# Example:
#   q what is the capital of France
#
# Uses pi with read-only tools (web search, file reading).

if ! command -v pi &>/dev/null; then
  echo "✗ 'pi' not found. Install: curl -fsSL https://pi.dev/install.sh | sh" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  echo "Usage: q <question>" >&2
  exit 1
fi

local question="$*"

# Ensure the questions working directory exists
local qdir="$HOME/.questions"
[[ -d "$qdir" ]] || mkdir -p "$qdir"
cd "$qdir"

# ── System prompt ──
local system_prompt="You are a helpful, concise assistant running in a macOS terminal. The user has asked a question. Answer it clearly and accurately. You can read files from disk and search the web — use those when you need current or file-specific information. Keep answers concise but thorough."

# ── Answer ──
print -P ""
print -P "%F{cyan}┌─────────────────────────────────────────────%f"
print -P "%F{cyan}│ Question:%f %F{yellow}$question%f"
print -P "%F{cyan}└─────────────────────────────────────────────%f"
print -P ""

pi --print -p \
  --system-prompt "$system_prompt" \
  --tools "read,web_search,url_extract,web_fetch,batch_web_fetch" \
  "$question"

local ret=$?
print -P ""
[[ $ret -ne 0 ]] && print -P "%F{red}✗ Failed to get answer.%f"
exit $ret
