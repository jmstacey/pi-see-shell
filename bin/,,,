#!/usr/bin/env zsh
# Run one Pi read/edit/write action, then return control.

if ! command -v pi &>/dev/null; then
  echo "✗ 'pi' not found." >&2; exit 1
fi
[[ $# -eq 0 ]] && { echo "Usage: ,,, <what to read, edit, or write>" >&2; exit 1; }

local system_prompt="You are a precise file editing assistant on macOS. Perform exactly ONE file action: read a file, edit a file, or write a file. Do that one action and stop. Do not chain operations or make multiple edits in one pass."

print -P ""
print -P "%F{cyan}│ File action:%f %F{yellow}$*%f"
print -P ""

local pi_model_args=()
[[ -n "${PI_SEE_SHELL_PROVIDER:-}" ]] && pi_model_args+=(--provider "$PI_SEE_SHELL_PROVIDER")
[[ -n "${PI_SEE_SHELL_MODEL:-}" ]] && pi_model_args+=(--model "$PI_SEE_SHELL_MODEL")

pi --print -p \
  "${pi_model_args[@]}" \
  --tools "read,write" \
  --no-extensions \
  --no-skills \
  --no-context-files \
  --no-prompt-templates \
  --no-themes \
  --no-session \
  --offline \
  --thinking "${PI_SEE_SHELL_THINKING:-off}" \
  --system-prompt "$system_prompt" \
  "$*"
