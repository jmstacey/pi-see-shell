#!/usr/bin/env zsh
# Run one bounded Pi read/search/edit/write pass, then return control.
# No Bash tool is exposed.

if ! command -v pi &>/dev/null; then
  echo "✗ 'pi' not found." >&2; exit 1
fi
[[ $# -eq 0 ]] && { echo "Usage: ,, <what to read, search, edit, or write>" >&2; exit 1; }

local system_prompt="You are a precise file editing assistant on macOS. Perform exactly ONE bounded action pass. You may read files, search the web, edit files, or write files. Do not run shell commands. Do not chain multiple independent tasks. If you need to modify files, make the smallest safe edit and then stop."

print -P ""
print -P "%F{cyan}│ Edit action:%f %F{yellow}$*%f"
print -P ""

local pi_model_args=()
[[ -n "${PI_SEE_SHELL_PROVIDER:-}" ]] && pi_model_args+=(--provider "$PI_SEE_SHELL_PROVIDER")
[[ -n "${PI_SEE_SHELL_MODEL:-}" ]] && pi_model_args+=(--model "$PI_SEE_SHELL_MODEL")

pi --print -p \
  "${pi_model_args[@]}" \
  --tools "read,web_search,url_extract,web_fetch,batch_web_fetch,edit,write" \
  --no-extensions \
  --no-skills \
  --no-context-files \
  --no-prompt-templates \
  --no-themes \
  --no-session \
  --offline \
  --thinking "${PI_SEE_SHELL_THINKING:-off}" \
  --system-prompt "$system_prompt" \
  "$*"
