#!/usr/bin/env zsh
# Run one bounded Pi read/search/edit/write pass, then return control.
# No Bash tool is exposed.

if ! command -v pi &>/dev/null; then
  echo "✗ 'pi' not found." >&2; exit 1
fi
[[ $# -eq 0 ]] && { echo "Usage: ,, <what to read, search, edit, or write>" >&2; exit 1; }

source "${0:A:h}/.pi-see-shell-question.zsh"

local target_os
target_os="$(pi_see_shell_target_os)"
local system_prompt="You are a helpful, concise assistant running in a ${target_os} terminal. Answer clearly and accurately. You can read files from disk and search the web — use those when you need current or file-specific information."

print -P ""
print -P "%F{cyan}│ Edit action:%f %F{yellow}$*%f"
print -P ""

local pi_model_args=()
[[ -n "${PI_SEE_SHELL_PROVIDER:-}" ]] && pi_model_args+=(--provider "$PI_SEE_SHELL_PROVIDER")
[[ -n "${PI_SEE_SHELL_MODEL:-}" ]] && pi_model_args+=(--model "$PI_SEE_SHELL_MODEL")

local -a pi_cmd=(
  pi
  --print -p
  "${pi_model_args[@]}"
  --no-extensions
  -e "$(pi_see_shell_openrouter_preset_extension_path)"
  --tools "read,web_search,url_extract,web_fetch,batch_web_fetch,edit,write"
  --no-skills
  --no-context-files
  --no-prompt-templates
  --no-themes
  --no-session
  --thinking "${PI_SEE_SHELL_THINKING:-off}"
  --system-prompt "$system_prompt"
  "$*"
 )

pi_see_shell_debug_pi_command "${pi_cmd[@]}"

"${pi_cmd[@]}"
