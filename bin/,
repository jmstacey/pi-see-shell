#!/usr/bin/env zsh
# Propose one shell command or patch action. Nothing runs.
# Run ,, to confirm and execute.

if ! command -v pi &>/dev/null; then
  echo "✗ 'pi' not found." >&2; exit 1
fi
[[ $# -eq 0 ]] && { echo "Usage: , <describe what you want>" >&2; exit 1; }

local system_prompt="You are a shell command suggestion engine running in ZSH on macOS. Output exactly one shell command — no explanation, no markdown, no backticks. Just the raw command on a single line."

print -P ""
print -P "%F{cyan}│ Suggest:%f %F{yellow}$*%f"
print -P ""

local cmd
cmd=$(pi --print -p \
  --no-tools \
  --no-extensions \
  --no-skills \
  --no-session \
  --thinking off \
  --system-prompt "$system_prompt" \
  "$*" 2>/dev/null)

[[ $? -ne 0 || -z "$cmd" ]] && { echo "✗ Failed." >&2; exit 1; }
cmd="${cmd//\`/}"; cmd="${cmd//$'\n'/}"; cmd="${cmd//$'\r'/}"; cmd="${cmd## }"; cmd="${cmd%% }"

echo -n "$cmd" | pbcopy
print -P "%F{yellow}$cmd%f"
print -P "\n%F{240}(copied — confirm and run with ,,)%f"
