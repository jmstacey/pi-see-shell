#!/usr/bin/env zsh
# Propose one shell command or patch action. Nothing runs.
# Paste or edit the copied command yourself before running.

if ! command -v pi &>/dev/null; then
  echo "✗ 'pi' not found." >&2; exit 1
fi
[[ $# -eq 0 ]] && { echo "Usage: , <describe what you want>" >&2; exit 1; }

source "${0:A:h}/.pi-see-shell-question.zsh"

local target_os
target_os="$(pi_see_shell_target_os)"
local system_prompt="Output exactly one shell command for ${target_os}. Use no numbering, no explanation, no markdown, no backticks. Just the raw command on a single line."

print -P ""
print -P "%F{cyan}│ Suggested command:%f"
print -P ""

local -a reply
pi_see_shell_build_pi_cmd command \
  "$system_prompt" \
  "${PI_SEE_SHELL_THINKING:-off}" \
  "$*" \
  --offline

pi_see_shell_debug_pi_command "${reply[@]}"

local cmd
cmd="$(${reply[@]})"

[[ $? -ne 0 || -z "$cmd" ]] && { echo "✗ Failed." >&2; exit 1; }
cmd="$(printf '%s' "$cmd" | pi_see_shell_extract_command)"
cmd="${cmd//\`/}"; cmd="${cmd//$'\n'/}"; cmd="${cmd//$'\r'/}"; cmd="${cmd## }"; cmd="${cmd%% }"
[[ -z "$cmd" ]] && { echo "✗ Failed." >&2; exit 1; }

echo -n "$cmd" | pbcopy
print -P "%F{yellow}$cmd%f"
print -P "\n%F{240}(copied)%f"
