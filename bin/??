#!/usr/bin/env zsh
# Continue the previous question in the same shell session.

if ! command -v pi &>/dev/null; then
  echo "✗ 'pi' not found." >&2; exit 1
fi
[[ $# -eq 0 ]] && { echo "Usage: ?? <follow-up question>" >&2; exit 1; }

source "${0:A:h}/.pi-see-shell-question.zsh"

local transcript_file
transcript_file="$(pi_see_shell_transcript_path)"
if [[ ! -f "$transcript_file" ]]; then
  print -P "%F{red}✗ No active question. Start one with: ? <question>%f" >&2
  exit 1
fi

local mode system_prompt prompt answer ret
mode="$(pi_see_shell_read_mode)"
system_prompt="$(pi_see_shell_system_prompt "$mode")"
prompt="$(pi_see_shell_followup_prompt "$*")"

printf '%s' "$*" | pi_see_shell_append_turn user

print -P ""
print -P "%F{cyan}│ ??%f %F{yellow}$*%f"
print -P ""

answer="$(pi --print -p \
  --system-prompt "$system_prompt" \
  --tools "read,web_search,url_extract,web_fetch,batch_web_fetch" \
  --no-extensions \
  --no-skills \
  --no-context-files \
  --no-session \
  "$prompt")"
ret=$?

if [[ $ret -ne 0 ]]; then
  print -P "%F{red}✗ Failed.%f"
  exit $ret
fi

printf '%s' "$answer" | pi_see_shell_append_turn assistant
print -r -- "$answer"
